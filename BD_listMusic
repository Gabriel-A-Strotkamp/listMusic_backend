--Tabelas--
CREATE TABLE Cantor (
    id_cantor serial not null PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    data_nascimento DATE,
    nacionalidade VARCHAR(50)
);

CREATE TABLE Genero (
    id_genero serial not null PRIMARY KEY,
    descricao VARCHAR(50) NOT NULL
);

CREATE TABLE Gravadora (
    id_gravadora serial not null PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    pais VARCHAR(50)
);

CREATE TABLE Musica (
    id_musica serial not null PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    ano INT,
    album VARCHAR(100),
    duracao TIME,
    id_cantor INT,
    id_genero INT,
    id_gravadora INT,

    FOREIGN KEY (id_cantor) REFERENCES Cantor(id_cantor),
    FOREIGN KEY (id_genero) REFERENCES Genero(id_genero),
    FOREIGN KEY (id_gravadora) REFERENCES Gravadora(id_gravadora)
);

