-- Listar músicas com cantor e gênero
SELECT 
    m.nome AS musica,
    c.nome AS cantor,
    g.descricao AS genero
FROM Musica m
JOIN Cantor c ON m.id_cantor = c.id_cantor
JOIN Genero g ON m.id_genero = g.id_genero;